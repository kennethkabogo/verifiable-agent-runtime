{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "KeyAdministration",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Create*",
        "kms:Describe*",
        "kms:Enable*",
        "kms:List*",
        "kms:Put*",
        "kms:Update*",
        "kms:Revoke*",
        "kms:Disable*",
        "kms:Get*",
        "kms:Delete*",
        "kms:TagResource",
        "kms:UntagResource",
        "kms:ScheduleKeyDeletion",
        "kms:CancelKeyDeletion"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowEncrypt",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowDecryptOnlyFromVerifiedEnclave",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEqualsIgnoreCase": {
          "kms:RecipientAttestation:PCR0": "7a9dc6e68a9c1400b52d177a9c5cba129b01dfcf6222b7dd377e6d5eb7fb166f15e819a4fcc547a485047954fe8e2510",
          "kms:RecipientAttestation:PCR1": "4b4d5b3661b3efc12920900c80e126e4ce783c522de6c02a2a5bf7af3a2b9327b86776f188e4be1c1c404a129dbda493",
          "kms:RecipientAttestation:PCR2": "91eea707766d0651ca4943621f4ac0acf527b546a3c0f246a6eb766dde66b0320eefefa62e592f61a81c529a03ab86c4"
        }
      }
    }
  ]
}
