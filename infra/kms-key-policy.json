{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RootFullAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationReadOnly",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Describe*",
        "kms:List*",
        "kms:Get*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationMutating",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Create*",
        "kms:Enable*",
        "kms:Put*",
        "kms:Update*",
        "kms:Revoke*",
        "kms:Disable*",
        "kms:Delete*",
        "kms:TagResource",
        "kms:UntagResource",
        "kms:ScheduleKeyDeletion",
        "kms:CancelKeyDeletion"
      ],
      "Resource": "*",
      "Condition": {
        "Bool": {
          "aws:MultiFactorAuthPresent": "true"
        }
      }
    },
    {
      "Sid": "AllowEncrypt",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowDecryptOnlyFromVerifiedEnclave",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEqualsIgnoreCase": {
          "kms:RecipientAttestation:PCR0": "b5eb961219df0c9d39ae7a04cf6497674f42b3f0fca3ee0d108fa1accacab9977f833dc52ec230f3873504cffa2f28c4",
          "kms:RecipientAttestation:PCR1": "4b4d5b3661b3efc12920900c80e126e4ce783c522de6c02a2a5bf7af3a2b9327b86776f188e4be1c1c404a129dbda493",
          "kms:RecipientAttestation:PCR2": "332bac91b9a68ab8e5574aaeac57b2676bed8d4c4436699175bb7f67d445b1680779bef3e33acfc6344a778d85b2de4b"
        }
      }
    }
  ]
}
