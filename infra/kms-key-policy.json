{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RootFullAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationReadOnly",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Describe*",
        "kms:List*",
        "kms:Get*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationMutating",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Create*",
        "kms:Enable*",
        "kms:Put*",
        "kms:Update*",
        "kms:Revoke*",
        "kms:Disable*",
        "kms:Delete*",
        "kms:TagResource",
        "kms:UntagResource",
        "kms:ScheduleKeyDeletion",
        "kms:CancelKeyDeletion"
      ],
      "Resource": "*",
      "Condition": {
        "Bool": {
          "aws:MultiFactorAuthPresent": "true"
        }
      }
    },
    {
      "Sid": "AllowEncrypt",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowDecryptOnlyFromVerifiedEnclave",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEqualsIgnoreCase": {
          "kms:RecipientAttestation:PCR0": "2770450cd3670333d64a2fed6b3ea28f3afd597efe12fe3f564fbb0d3a9987c96b12f446572c4113dc620bbe77cb48bc",
          "kms:RecipientAttestation:PCR1": "4b4d5b3661b3efc12920900c80e126e4ce783c522de6c02a2a5bf7af3a2b9327b86776f188e4be1c1c404a129dbda493",
          "kms:RecipientAttestation:PCR2": "0b3ca9a18d4377ff95945b28fafbe62d8c9b4dae8944e725ae6bc38230281893b33087ce0f52a1f85e6e86b183b62aef"
        }
      }
    }
  ]
}
