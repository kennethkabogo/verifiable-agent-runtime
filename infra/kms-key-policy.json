{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RootFullAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationReadOnly",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Describe*",
        "kms:List*",
        "kms:Get*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationMutating",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Create*",
        "kms:Enable*",
        "kms:Put*",
        "kms:Update*",
        "kms:Revoke*",
        "kms:Disable*",
        "kms:Delete*",
        "kms:TagResource",
        "kms:UntagResource",
        "kms:ScheduleKeyDeletion",
        "kms:CancelKeyDeletion"
      ],
      "Resource": "*",
      "Condition": {
        "Bool": {
          "aws:MultiFactorAuthPresent": "true"
        }
      }
    },
    {
      "Sid": "AllowEncrypt",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowDecryptOnlyFromVerifiedEnclave",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEqualsIgnoreCase": {
          "kms:RecipientAttestation:PCR0": "c70b4c9a1abfe385b5ef4d54453f93e470d2cb929497d5225dfb21c19758c216e1765963f819a0fa88efa7994181a975",
          "kms:RecipientAttestation:PCR1": "4b4d5b3661b3efc12920900c80e126e4ce783c522de6c02a2a5bf7af3a2b9327b86776f188e4be1c1c404a129dbda493",
          "kms:RecipientAttestation:PCR2": "edad79708717e0404fe7bf3781c7749fea6a30e6ad056632ca060a7f23270cec16d3f526c0839685e6d6fd2e331be034"
        }
      }
    }
  ]
}
