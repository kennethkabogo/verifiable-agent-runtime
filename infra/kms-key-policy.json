{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RootFullAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:root"
      },
      "Action": "kms:*",
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationReadOnly",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Describe*",
        "kms:List*",
        "kms:Get*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "KeyAdministrationMutating",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:user/kenneth-dev"
      },
      "Action": [
        "kms:Create*",
        "kms:Enable*",
        "kms:Put*",
        "kms:Update*",
        "kms:Revoke*",
        "kms:Disable*",
        "kms:Delete*",
        "kms:TagResource",
        "kms:UntagResource",
        "kms:ScheduleKeyDeletion",
        "kms:CancelKeyDeletion"
      ],
      "Resource": "*",
      "Condition": {
        "Bool": {
          "aws:MultiFactorAuthPresent": "true"
        }
      }
    },
    {
      "Sid": "AllowEncrypt",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": [
        "kms:Encrypt",
        "kms:GenerateDataKey",
        "kms:DescribeKey"
      ],
      "Resource": "*"
    },
    {
      "Sid": "AllowDecryptOnlyFromVerifiedEnclave",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::752439474140:role/var-enclave-host"
      },
      "Action": "kms:Decrypt",
      "Resource": "*",
      "Condition": {
        "StringEqualsIgnoreCase": {
          "kms:RecipientAttestation:PCR0": "5be726791c959b9a45dc9700f69cd53c589efb1832685656ac3980da029a242b64d67dd5e955538febfe167ebd2bc3fa",
          "kms:RecipientAttestation:PCR1": "4b4d5b3661b3efc12920900c80e126e4ce783c522de6c02a2a5bf7af3a2b9327b86776f188e4be1c1c404a129dbda493",
          "kms:RecipientAttestation:PCR2": "50890a2c13fe09669c752bf4311d631c048d830457ff9c72e2dfdfecd4b5936d0e5ef217ab60f936d61200cf7f2fff59"
        }
      }
    }
  ]
}
