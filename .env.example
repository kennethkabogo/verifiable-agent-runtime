# VAR — Verifiable Agent Runtime  ·  environment variable template
# Copy to .env and fill in real values before launching.
# Never commit .env to source control.
#
# Quick reference
# ───────────────
#   Enclave  →  VAR_PORT, VSOCK_CID, VAR_KMS_KEY_ARN, VAR_KMS_PROXY_PORT
#   Gateway  →  VAR_HOST, VAR_PORT
#   Agent    →  ANTHROPIC_API_KEY, VAR_HOST, VAR_PORT, VAR_GATEWAY
#   Host KMS →  VAR_KMS_PROXY_PORT, AWS_DEFAULT_REGION
#   Verifier →  VAR_GATEWAY
#   Skill    →  VAR_GATEWAY, SKILL_ID
#   Deploy   →  AWS_ACCOUNT_ID, AWS_DEFAULT_REGION, ECR_REPO, IMAGE_TAG

# ── Agent / Anthropic ──────────────────────────────────────────────────────────

# Anthropic API key used by the agent process inside the enclave.
# Obtain at https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Enclave ↔ Gateway (vsock / TCP) ───────────────────────────────────────────

# Vsock CID of the running enclave (Nitro default: 16).
# Ignored in simulation mode; the agent falls back to TCP via VAR_HOST.
VSOCK_CID=16

# TCP host the gateway and agent use when vsock is unavailable (simulation/dev).
VAR_HOST=127.0.0.1

# Port the VAR runtime listens on (vsock and TCP gateway use the same value).
VAR_PORT=5005

# ── HTTP Gateway ───────────────────────────────────────────────────────────────

# Base URL of the VAR HTTP gateway (used by the verifier and gateway_skill).
VAR_GATEWAY=http://127.0.0.1:8765

# ── KMS sealed-state (optional — enables hibernate/resume across reboots) ──────

# ARN of the AWS KMS CMK used to wrap the sealed-state DEK.
# Example: arn:aws:kms:us-east-1:123456789012:key/mrk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The key policy must allow the enclave's PCR0 measurement (see docs/kms-setup.md).
VAR_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/mrk-...

# Vsock port the host KMS proxy listens on (must match the enclave side).
# Default is 8443; change only if that port is already in use on the host.
VAR_KMS_PROXY_PORT=8443

# ── AWS credentials / region (host-side tooling) ───────────────────────────────

# AWS region for ECR, KMS, and STS calls.
AWS_DEFAULT_REGION=us-east-1

# AWS account ID — auto-detected by `make` via `aws sts get-caller-identity`
# but can be set explicitly to avoid the extra API call.
# AWS_ACCOUNT_ID=123456789012

# ── Deployment (Makefile overrides) ───────────────────────────────────────────

# ECR repository URI — defaults to <account>.dkr.ecr.<region>.amazonaws.com/var-enclave
# Override if you use a custom repository name.
# ECR_REPO=123456789012.dkr.ecr.us-east-1.amazonaws.com/var-enclave

# Docker image tag pushed to ECR and used when building the EIF.
IMAGE_TAG=latest

# ── Gateway skill ──────────────────────────────────────────────────────────────

# Identifier for the running skill instance (returned in gateway_skill responses).
SKILL_ID=demo-skill
