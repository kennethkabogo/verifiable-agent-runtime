# Verifiable Agent Runtime - Environment Configuration
# Copy this to .env and fill in the values for your Nitro deployment.

# The ARN of the KMS CMK used for state sealing.
# Your EC2 instance role must have kms:Encrypt/Decrypt permissions on this key.
# The key policy must also allow the enclave's PCR0 to call kms:Decrypt.
VAR_KMS_KEY_ARN=arn:aws:kms:us-east-1:123456789012:key/your-cmk-id

# The port where the host-side var-kms-proxy is listening.
# Default is 8000.
VAR_KMS_PROXY_PORT=8000

# Optional: The host and port for the internal HTTP gateway.
# Default is 127.0.0.1:8765.
# VAR_HOST=127.0.0.1
# VAR_PORT=8765
